{
    "name": "@frequency-app/api-gateway-e2e",
    "version": "0.0.1",
    "private": true,
    "nx": {
        "implicitDependencies": [
            "@frequency-app/api-gateway"
        ],
        "targets": {
            "e2e": {
                "executor": "@nx/jest:jest",
                "outputs": [
                    "{projectRoot}/test-output/jest/coverage"
                ],
                "options": {
                    "jestConfig": "apps/api-gateway-e2e/jest.config.cts",
                    "passWithNoTests": true
                },
                "dependsOn": [
                    "@frequency-app/api-gateway:build",
                    "@frequency-app/api-gateway:serve"
                ]
            }
        }
    }
}
